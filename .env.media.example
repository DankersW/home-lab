# Copy to .env (gitignored) and fill in. Compose auto-loads .env.

# rreading-glasses Postgres password — random, no special symbols.
RREADING_POSTGRES_PASSWORD=changeme

# Gluetun / WireGuard VPN credentials (from your VPN provider).
# Provider list: https://github.com/qdm12/gluetun-wiki
VPN_SERVICE_PROVIDER=mullvad
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=10.0.0.2/32
VPN_SERVER_COUNTRIES=Netherlands
